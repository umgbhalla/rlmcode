# Cloudflare Workers AI — required to run `bun run chat` against the real model.
# Create a token (Workers AI permission) + grab your account id from the CF dashboard.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional knobs (defaults shown / behavior noted):
# AX2_MAX_STEPS=50         # max tool-call steps per turn
# AX2_MOCK=1               # zero-credential path: canned AI, drives the real turn loop + TUI
# AX2_LIVE=1               # `bun run live` — real CF model authors + runs a workflow script
# TERMCTRL_BINARY=         # path to the termctrl binary (default: $HOME/.cargo/bin/termctrl)
