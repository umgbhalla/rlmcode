{
  "name": "ax2-loop-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "chat": "bun --env-file=.env src/chat.tsx",
    "emit": "bun --env-file=.env smoke-emit.ts",
    "motel": "bun --cwd ../motel run src/motel.ts server",
    "motel:tui": "bun --cwd ../motel run src/motel.ts tui",
    "check": "tsc --noEmit",
    "sdk:smoke": "bun examples/sdk-usage.ts",
    "analyze": "bun scripts/design-check.ts",
    "debt": "bun scripts/ponytail-debt.ts",
    "test": "bun scripts/design-check.test.ts && bun scripts/ponytail-debt.test.ts && bun scripts/orch-core.test.ts && bun scripts/orch.test.ts && bun scripts/orch-cost.test.ts && bun scripts/orch-retry.test.ts && bun scripts/orch-route.test.ts && bun scripts/orch-tree-render.test.ts && bun run test:tui",
    "test:tui": "bun scripts/tui/mock.test.ts",
    "test:tui:frame": "bun scripts/tui/smoke.test.ts && bun scripts/tui/focus.test.ts && bun scripts/tui/layout.test.ts && bun scripts/tui/node-tree.test.ts && bun scripts/tui/thinking-streaming.test.ts && bun scripts/tui/tool-grouping.test.ts",
    "live": "AX2_LIVE=1 bun --env-file=.env scripts/orch-live.test.ts",
    "live:focus": "AX2_FOCUS_LIVE=1 bun scripts/focus-live.test.ts",
    "lint": "bun run check && bun run test && bun run analyze && bun run debt",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@ax-llm/ax": "^22.0.5",
    "@effect/atom-react": "4.0.0-beta.85",
    "@effect/opentelemetry": "4.0.0-beta.85",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "effect": "4.0.0-beta.85",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3",
    "yuku-analyzer": "^0.5.39"
  }
}
