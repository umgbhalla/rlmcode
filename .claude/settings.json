{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "jumbo session start"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "jumbo work resume"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "jumbo work pause"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(jumbo --help)"
    ]
  }
}
